echo "Running build check..."
npm run build

if [ $? -ne 0 ]; then
  echo "BUILD FAILED. Push rejected."
  exit 1
fi

echo "Running unit tests..."
npx vitest run --exclude ".claude/worktrees/**"

if [ $? -ne 0 ]; then
  echo "UNIT TESTS FAILED. Push rejected."
  exit 1
fi

echo "All gates passed. E2E runs in GitHub Actions on deploy."
