echo "Running critical CI contract gate..."
npm run test:critical-ci-contracts

if [ $? -ne 0 ]; then
  echo "CRITICAL CI CONTRACT GATE FAILED. Push rejected."
  exit 1
fi

echo "Running build check..."

# On Windows, capturing large build output in a variable fails silently.
# Pipe directly so stdout is streamed. Use tee to a temp file to test for success.
TMPFILE=$(mktemp)
npm run build 2>&1 | tee "$TMPFILE"

# On Windows, Next.js build traces fail with ENOENT on .next/server files even when
# compilation succeeds. Pass if compilation succeeded regardless of trace errors.
if grep -q "Compiled successfully" "$TMPFILE"; then
  echo "Build compiled successfully."
  rm -f "$TMPFILE"
else
  echo "BUILD FAILED. Push rejected."
  rm -f "$TMPFILE"
  exit 1
fi

echo "Running unit tests..."
npx vitest run --exclude ".claude/worktrees/**"

if [ $? -ne 0 ]; then
  echo "UNIT TESTS FAILED. Push rejected."
  exit 1
fi

# Cheap structural guard against known e2e assertion bug classes
# (raw-markdown assertions against ReactMarkdown containers, .only leaks).
# Runs in <1s, zero network. See scripts/lint-e2e-assertions.mjs.
echo "Linting e2e assertions..."
npm run test:ci:e2e:lint

if [ $? -ne 0 ]; then
  echo "E2E ASSERTION LINT FAILED. Push rejected."
  exit 1
fi

# Opt out with SKIP_E2E_SMOKE=1 git push when iterating on non-frontend code.
if [ "${SKIP_E2E_SMOKE:-0}" = "1" ]; then
  echo "SKIP_E2E_SMOKE=1 set — skipping public-routes smoke."
else
  echo "Running e2e smoke lane (public-routes only)..."
  npm run test:ci:e2e:smoke

  if [ $? -ne 0 ]; then
    echo "E2E SMOKE FAILED. Push rejected."
    echo "To push anyway (emergency only): SKIP_E2E_SMOKE=1 git push"
    exit 1
  fi
fi

echo "All gates passed. Full authenticated + flow e2e runs in GitHub Actions."
