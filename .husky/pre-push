# ─────────────────────────────────────────────────────────────────────────────
# Pre-push — local guard. Deliberately short. Heavy verification lives in CI.
#
# Default gate (<30s when smoke is on):
#   1. E2E assertion linter       (~<1s; locks out raw-markdown + .only leaks)
#   2. Next build                 (~2m; doubles as a typecheck)
#   3. Public-routes e2e smoke    (~24s; catches marketing/shell regressions)
#
# Unit tests, the authenticated e2e flow, and payments lanes are CI's job.
# CI also gates on the same assertion linter, so there is zero local/remote
# policy drift.
#
# Escape hatches (in order of scope):
#   SKIP_E2E_SMOKE=1  git push   # skip only the public-routes smoke lane
#   FULL_PREPUSH=1    git push   # also run unit tests locally (mirrors CI)
#   HUSKY=0           git push   # emergency bypass; use sparingly
#
# If a push is blocked here, the failing lane names the exact next move.
# ─────────────────────────────────────────────────────────────────────────────

echo "Running e2e assertion linter..."
npm run test:ci:e2e:lint
if [ $? -ne 0 ]; then
  echo "E2E ASSERTION LINT FAILED. Push rejected."
  exit 1
fi

echo "Running build (Next.js full typecheck)..."
# On Windows, capturing large build output in a variable fails silently.
# Pipe directly so stdout is streamed. Use tee to a temp file to test for success.
TMPFILE=$(mktemp)
npm run build 2>&1 | tee "$TMPFILE"

# On Windows, Next.js build traces occasionally fail with ENOENT on .next/server
# files even when compilation succeeded. Pass if compilation succeeded regardless
# of trace errors.
if grep -q "Compiled successfully" "$TMPFILE"; then
  echo "Build compiled successfully."
  rm -f "$TMPFILE"
else
  echo "BUILD FAILED. Push rejected."
  rm -f "$TMPFILE"
  exit 1
fi

if [ "${FULL_PREPUSH:-0}" = "1" ]; then
  echo "FULL_PREPUSH=1 — running unit tests locally (mirrors CI)..."
  npx vitest run --exclude ".claude/worktrees/**"
  if [ $? -ne 0 ]; then
    echo "UNIT TESTS FAILED. Push rejected."
    exit 1
  fi
fi

if [ "${SKIP_E2E_SMOKE:-0}" = "1" ]; then
  echo "SKIP_E2E_SMOKE=1 — skipping public-routes smoke lane."
else
  echo "Running e2e smoke lane (public-routes only)..."
  npm run test:ci:e2e:smoke
  if [ $? -ne 0 ]; then
    echo "E2E SMOKE FAILED. Push rejected."
    echo "To push anyway (emergency only): SKIP_E2E_SMOKE=1 git push"
    exit 1
  fi
fi

echo "All local gates passed. Full CI runs in GitHub Actions:"
echo "  - unit tests (every code change)"
echo "  - authenticated + flow e2e (dashboard/payments/settings changes)"
echo "  - quarantine lane (report-only)"
