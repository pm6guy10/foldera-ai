echo "Running critical briefing runtime gate..."
npm run test:briefing-runtime-gate

if [ $? -ne 0 ]; then
  echo "CRITICAL BRIEFING RUNTIME GATE FAILED. Push rejected."
  exit 1
fi

echo "Running build check..."

# On Windows, capturing large build output in a variable fails silently.
# Pipe directly so stdout is streamed. Use tee to a temp file to test for success.
TMPFILE=$(mktemp)
npm run build 2>&1 | tee "$TMPFILE"

# On Windows, Next.js build traces fail with ENOENT on .next/server files even when
# compilation succeeds. Pass if compilation succeeded regardless of trace errors.
if grep -q "Compiled successfully" "$TMPFILE"; then
  echo "Build compiled successfully."
  rm -f "$TMPFILE"
else
  echo "BUILD FAILED. Push rejected."
  rm -f "$TMPFILE"
  exit 1
fi

echo "Running unit tests..."
npx vitest run --exclude ".claude/worktrees/**"

if [ $? -ne 0 ]; then
  echo "UNIT TESTS FAILED. Push rejected."
  exit 1
fi

echo "All gates passed. E2E runs in GitHub Actions on deploy."
