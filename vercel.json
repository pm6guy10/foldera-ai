{
  "framework": "nextjs",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-generate",
      "schedule": "50 13 * * *"
    },
    {
      "path": "/api/cron/daily-send",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/growth-scanner",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/sync-google",
      "schedule": "0 2 * * *"
    }
  ]
}
