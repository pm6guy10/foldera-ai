{
  "name": "bulldog-autopilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:e2e": "playwright test",
    "audit:smoke": "npx playwright test --config=playwright.audit.config.ts",
    "audit:ux": "npx tsx scripts/ux-audit.ts",
    "audit:all": "npx playwright test --config=playwright.audit.config.ts && npx tsx scripts/ux-audit.ts",
    "test:prod:setup": "npx tsx tests/production/setup-auth.ts",
    "test:prod": "npx playwright test --config playwright.prod.config.ts",
    "test:prod:ci": "npx playwright test --config playwright.prod.config.ts --reporter=list",
    "test:prod:refresh": "npx tsx tests/production/refresh-auth.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@sentry/nextjs": "^10.45.0",
    "@supabase/supabase-js": "^2.57.0",
    "dotenv": "^17.2.2",
    "framer-motion": "^12.23.12",
    "googleapis": "^160.0.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.542.0",
    "next": "^14.2.32",
    "next-auth": "^4.24.11",
    "p-retry": "^6.2.1",
    "react": "^18",
    "react-dom": "^18",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "resend": "^6.1.2",
    "stripe": "^18.5.0",
    "svix": "^1.87.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.15",
    "autoprefixer": "^10.4.21",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "husky": "^9.1.7",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "supabase": "^2.39.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8"
  }
}
