# Foldera — required environment variables.
# Copy to .env.local and fill in. These are the vars needed to run end-to-end.
# Anything not listed here has a sensible default in code or is optional.

# --- Supabase (data + auth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App / NextAuth ---
NEXTAUTH_SECRET=
NEXT_PUBLIC_BASE_URL=

# --- LLM + embeddings ---
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# --- Slack delivery ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
FOLDERA_SLACK_SELF_CHANNEL_ID=
FOLDERA_SELF_USER_ID=

# --- Google OAuth (Gmail / Calendar / Drive) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft OAuth (mail / calendar) ---
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# --- Crypto + cron ---
ENCRYPTION_KEY=
CRON_SECRET=

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
