# =============================================================================
# Foldera — environment template (placeholders only; copy to .env.local)
# =============================================================================

# --- Required for NextAuth / middleware ---
NEXTAUTH_SECRET=your-secret-here
# Local dev: http://localhost:3000  Production: https://www.foldera.ai
NEXTAUTH_URL=http://localhost:3000

# --- Public site URL (metadata, redirects, emails) ---
NEXT_PUBLIC_BASE_URL=https://foldera.ai

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Encryption (32-byte key, base64) ---
ENCRYPTION_KEY=your-base64-32-byte-key
# Optional: decrypt legacy ciphertext after key rotation
# ENCRYPTION_KEY_LEGACY=

# --- Anthropic (briefing, extraction, try demo) ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Google OAuth (Gmail / Calendar / sync) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft OAuth (Azure AD) ---
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
# Optional; default "common" in code
# AZURE_AD_TENANT_ID=common

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Foldera <brief@foldera.ai>
# Ops / health alert recipient
DAILY_BRIEF_TO_EMAIL=ops@yourdomain.com
RESEND_WEBHOOK_SECRET=

# --- Cron / background auth ---
CRON_SECRET=your-cron-bearer-secret
# Ingest pipeline user (cron only; not session users)
INGEST_USER_ID=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- Observability ---
SENTRY_DSN=

# --- Dev-only routes (/api/dev/*, stress-test, brain-receipt, etc.) ---
# Set to "true" only in local/dev; leave unset in production
ALLOW_DEV_ROUTES=

# --- Playwright / CI (optional) ---
# BASE_URL=http://localhost:3000
# CI=1
# PLAYWRIGHT_AUTH_STATE_PATH=tests/production/auth-state.json
