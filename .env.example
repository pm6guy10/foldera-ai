# =============================================================================
# Foldera — environment template (placeholders only; copy to .env.local)
# =============================================================================

# --- Required for NextAuth / middleware ---
NEXTAUTH_SECRET=your-secret-here
# Local dev: http://localhost:3000  Production: https://www.foldera.ai
NEXTAUTH_URL=http://localhost:3000
# When `next dev` binds to another port (e.g. 3001), set for test:local:setup / test:local:brain-receipt
# LOCAL_BASE_URL=http://localhost:3001

# --- Public site URL (metadata, redirects, emails) ---
NEXT_PUBLIC_BASE_URL=https://foldera.ai

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Encryption (32-byte key, base64) ---
ENCRYPTION_KEY=your-base64-32-byte-key
# Optional: decrypt legacy ciphertext after key rotation
# ENCRYPTION_KEY_LEGACY=

# --- Anthropic (briefing, extraction, try demo) ---
ANTHROPIC_API_KEY=your-anthropic-api-key
# Soft monthly budget (cents) for ops visibility; hard enforcement is Postgres `api_budget_check_and_reserve` (see Supabase).
ANTHROPIC_MONTHLY_BUDGET_CENTS=3000
# Real api.anthropic.com calls — owner proof runs only. Leave unset for normal dev/CI (fail-closed in code).
# ALLOW_PAID_LLM=

# --- Google OAuth (Gmail / Calendar / sync) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft OAuth (Azure AD) ---
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
# Optional; default "common" in code
# AZURE_AD_TENANT_ID=common

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Foldera <noreply@foldera.ai>
# Ops / health alert recipient
DAILY_BRIEF_TO_EMAIL=ops@yourdomain.com
RESEND_WEBHOOK_SECRET=

# --- Cron / background auth ---
CRON_SECRET=your-cron-bearer-secret
# Ingest pipeline user (cron only; not session users)
INGEST_USER_ID=

# --- Stripe (set in Vercel for production) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRO_PRICE_ID=price_1TF00IRrgMYs6VrdugNcEC9z
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Observability ---
SENTRY_DSN=
# Optional: read-only API token for agent triage of production issues (local CLI / Cursor), not required for app runtime
# SENTRY_AUTH_TOKEN=

# --- Dev-only routes (/api/dev/*, stress-test, brain-receipt, etc.) ---
# Set to "true" only in local/dev; leave unset in production
ALLOW_DEV_ROUTES=

# Set in .env.local — makes Generate Now free, no Anthropic calls for directive generation
FOLDERA_DRY_RUN=true

# Set to true only for local scorer experiments (forces decay/reconnect to rank #1).
# SCORER_FORCE_DECAY_WINNER=

# --- Playwright / CI (optional) ---
# BASE_URL=http://localhost:3000
# CI=1
# PLAYWRIGHT_AUTH_STATE_PATH=tests/production/auth-state.json

# --- GitHub Actions: autonomous agents (optional) ---
# Repo secrets: AGENT_BASE_URL=https://www.foldera.ai, CRON_SECRET, ANTHROPIC_API_KEY
# See .github/workflows/agent-*.yml

# --- PostHog (optional — lib/agents/self-optimizer.ts) ---
# POSTHOG_PERSONAL_API_KEY=
# POSTHOG_PROJECT_ID=

# --- Runtime (set by host; do not put secrets here) ---
# NODE_ENV=development
# VERCEL=1
# Optional: Vercel CLI logs/inspect for post-deploy triage (GitHub Actions deploy workflow uses repo secret VERCEL_TOKEN)
# VERCEL_TOKEN=

# --- Playwright (optional overrides) ---
# PLAYWRIGHT_TEST_BASE_URL=http://localhost:3000
# PLAYWRIGHT_WEB_PORT=3011
#   When set, playwright.config.ts runs `next start -p <port>` (use with CI=true if :3000 is busy). Match authenticated-routes E2E_ORIGIN.
